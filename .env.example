# Copy this to .env and fill in values
# NEVER commit .env to GitHub

# ── Data & Storage ──
# Directory for runtime data (database, uploads, ChromaDB)
FINSENTINEL_DATA_DIR=runtime

# SQLite database path
FINSENTINEL_DB_PATH=runtime/finsentinel.db

# ── AI Models ──
# Ollama LLM model name
FINSENTINEL_MODEL_NAME=mistral:7b-instruct-q4_K_M

# Sentence-transformers embedding model
FINSENTINEL_EMBED_MODEL=all-MiniLM-L6-v2

# Ollama API endpoint
OLLAMA_ENDPOINT=http://127.0.0.1:11434/api/generate

# ── Security ──
# JWT secret (generate with: python -c "import secrets; print(secrets.token_hex(32))")
FINSENTINEL_JWT_SECRET=generate_a_random_secret_here

# Encryption key for sensitive data
FINSENTINEL_ENCRYPTION_KEY=generate_a_random_key_here

# JWT token expiry in minutes (default: 60)
FINSENTINEL_TOKEN_EXPIRY_MINUTES=60

# ── CORS (comma-separated origins for production) ──
FINSENTINEL_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ── Logging ──
LOG_LEVEL=INFO
