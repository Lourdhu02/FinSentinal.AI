# Copy this to .env and fill in values
# NEVER commit .env to GitHub

# Master encryption password (you choose this)
FINSENTINEL_MASTER_PASSWORD=change_this_strong_password

# Ollama settings (keep local!)
OLLAMA_HOST=127.0.0.1
OLLAMA_PORT=11434
OLLAMA_MODEL=mistral:7b-instruct-q4_K_M

# Database path
DB_PATH=data/finsentinel.db
FAISS_PATH=data/faiss_index

# JWT secret (generate with: python -c "import secrets; print(secrets.token_hex(32))")
JWT_SECRET=generate_a_random_secret_here

# Logging
LOG_LEVEL=INFO
